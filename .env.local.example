# Supabase — lead capture (server-side insert).
# Copy to .env.local and fill in from your Supabase project:
#   Project Settings → API
#
# The URL is public; the SERVICE ROLE key is SECRET and used only on the server
# (never prefixed with NEXT_PUBLIC_, never sent to the browser).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
